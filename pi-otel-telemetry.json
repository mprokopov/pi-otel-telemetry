    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mCUDBhx4z"
      },
      "description": "Session duration over time (p50, p95)",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
