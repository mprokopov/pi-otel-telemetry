{
  "__elements": {},
  "__requires": [
    {
      "id": "grafana",
      "name": "Grafana",
      "type": "grafana",
      "version": "11.0.0"
    },
    {
      "id": "prometheus",
      "name": "Prometheus",
      "type": "datasource",
      "version": "1.0.0"
    },
    {
      "id": "tempo",
      "name": "Tempo",
      "type": "datasource",
      "version": "1.0.0"
    },
    {
      "id": "timeseries",
      "name": "Time series",
      "type": "panel",
      "version": ""
    },
    {
      "id": "stat",
      "name": "Stat",
      "type": "panel",
      "version": ""
    },
    {
      "id": "barchart",
      "name": "Bar chart",
      "type": "panel",
      "version": ""
    },
    {
      "id": "piechart",
      "name": "Pie chart",
      "type": "panel",
      "version": ""
    },
    {
      "id": "table",
      "name": "Table",
      "type": "panel",
      "version": ""
    },
    {
      "id": "histogram",
      "name": "Histogram",
      "type": "panel",
      "version": ""
    }
  ],
  "description": "OpenTelemetry traces & metrics for pi coding agent sessions",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": [],
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mCUDBhx4z"
      },
      "description": "Total user prompts sent to the agent",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 10
              },
              {
                "color": "yellow",
                "value": 100
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(pi_prompts{job=\"pi-coding-agent\"})",
          "legendFormat": "Prompts",
          "refId": "A"
        }
      ],
      "title": "Total Prompts",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mCUDBhx4z"
      },
      "description": "Total LLM turns (one turn = one LLM call + tool executions)",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 50
              },
              {
                "color": "yellow",
                "value": 500
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(pi_turns{job=\"pi-coding-agent\"})",
          "legendFormat": "Turns",
          "refId": "A"
        }
      ],
      "title": "Total Turns",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mCUDBhx4z"
      },
      "description": "Total tool invocations across all sessions",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "purple",
                "value": null
              },
              {
                "color": "green",
                "value": 50
              },
              {
                "color": "orange",
                "value": 500
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(pi_tool_calls{job=\"pi-coding-agent\"})",
          "legendFormat": "Tool Calls",
          "refId": "A"
        }
      ],
      "title": "Total Tool Calls",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mCUDBhx4z"
      },
      "description": "Total failed tool executions",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(pi_tool_errors{job=\"pi-coding-agent\"}) or vector(0)",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "title": "Tool Errors",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mCUDBhx4z"
      },
      "description": "Total input tokens consumed",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1000000
              },
              {
                "color": "red",
                "value": 10000000
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(pi_tokens_input{job=\"pi-coding-agent\"})",
          "legendFormat": "Input",
          "refId": "A"
        }
      ],
      "title": "Input Tokens",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mCUDBhx4z"
      },
      "description": "Total output tokens produced",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500000
              },
              {
                "color": "red",
                "value": 5000000
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(pi_tokens_output{job=\"pi-coding-agent\"})",
          "legendFormat": "Output",
          "refId": "A"
        }
      ],
      "title": "Output Tokens",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "panels": [],
      "title": "Token Usage",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mCUDBhx4z"
      },
      "description": "Input and output tokens per minute",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineInterpolation": "smooth",
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true,
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Input"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Output"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(pi_tokens_input{job=\"pi-coding-agent\"}[5m])) * 60",
          "legendFormat": "Input",
          "refId": "A"
        },
        {
          "expr": "sum(rate(pi_tokens_output{job=\"pi-coding-agent\"}[5m])) * 60",
          "legendFormat": "Output",
          "refId": "B"
        }
      ],
      "title": "Token Consumption Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mCUDBhx4z"
      },
      "description": "Total token consumption broken down by model",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "smooth",
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "options": {
        "legend": {
          "calcs": [
            "sum"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (llm_model) (rate(pi_tokens_input{job=\"pi-coding-agent\"}[5m]) + rate(pi_tokens_output{job=\"pi-coding-agent\"}[5m])) * 60",
          "legendFormat": "{{llm_model}}",
          "refId": "A"
        }
      ],
      "title": "Tokens by Model",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "panels": [],
      "title": "Tool Usage",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mCUDBhx4z"
      },
      "description": "Breakdown of tool calls by tool name",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 15
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "sum by (tool_name) (pi_tool_calls{job=\"pi-coding-agent\"})",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ],
      "title": "Tool Call Distribution",
      "type": "piechart"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mCUDBhx4z"
      },
      "description": "Tool invocations per minute by tool name",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 15
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (tool_name) (rate(pi_tool_calls{job=\"pi-coding-agent\"}[5m])) * 60",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ],
      "title": "Tool Calls Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mCUDBhx4z"
      },
      "description": "Distribution of tool execution times",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 15
      },
      "options": {
        "bucketSize": 100,
        "combine": false,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (le, tool_name) (rate(pi_tool_duration_bucket{job=\"pi-coding-agent\"}[5m]))",
          "format": "heatmap",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ],
      "title": "Tool Execution Duration",
      "type": "histogram"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mCUDBhx4z"
      },
      "description": "Average and p95 execution time per tool",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Avg Duration"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "decimals",
                "value": 1
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "P95 Duration"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "decimals",
                "value": 1
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Error Rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 0.05
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 23
      },
      "options": {
        "footer": {
          "enablePagination": false
        }
      },
      "targets": [
        {
          "expr": "sum by (tool_name) (pi_tool_calls{job=\"pi-coding-agent\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "expr": "sum by (tool_name) (pi_tool_duration_sum{job=\"pi-coding-agent\"}) / sum by (tool_name) (pi_tool_duration_count{job=\"pi-coding-agent\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, tool_name) (rate(pi_tool_duration_bucket{job=\"pi-coding-agent\"}[1h])))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "C"
        },
        {
          "expr": "sum by (tool_name) (pi_tool_errors{job=\"pi-coding-agent\"}) / sum by (tool_name) (pi_tool_calls{job=\"pi-coding-agent\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "D"
        }
      ],
      "title": "Tool Performance Summary",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "Total Calls",
              "Value #B": "Avg Duration",
              "Value #C": "P95 Duration",
              "Value #D": "Error Rate",
              "tool_name": "Tool"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "mCUDBhx4z"
      },
      "description": "Failed tool executions per minute",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 23
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (tool_name) (rate(pi_tool_errors{job=\"pi-coding-agent\"}[5m])) * 60",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ],
      "title": "Tool Errors Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
