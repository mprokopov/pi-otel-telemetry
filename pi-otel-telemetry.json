        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(pi_session_duration_bucket{job=\"pi-coding-agent\"}[1h])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "title": "Session Duration",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
